<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoCity Admin</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            --admin-primary: #6366f1;
            --admin-secondary: #8b5cf6;
            --admin-success: #10b981;
            --admin-warning: #f59e0b;
            --admin-danger: #ef4444;
            --admin-dark: #1f2937;
            --admin-darker: #111827;
            --glass-bg: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 15px;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        }

        .sidebar {
            background: rgba(31, 41, 55, 0.8);
            backdrop-filter: blur(10px);
            border-right: 1px solid var(--glass-border);
            min-height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            z-index: 1000;
        }

        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 10px;
            transition: all 0.3s ease;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: var(--admin-primary);
            color: white;
        }

        .main-content {
            margin-left: 250px;
            padding: 20px;
        }

        .navbar-admin {
            background: rgba(31, 41, 55, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--glass-border);
            padding: 15px 30px;
        }

        .table-dark {
            background: rgba(0, 0, 0, 0.3);
        }

        .table-dark th,
        .table-dark td {
            border-color: var(--glass-border);
        }

        .btn-primary {
            background: var(--admin-primary);
            border-color: var(--admin-primary);
        }

        .btn-primary:hover {
            background: var(--admin-secondary);
            border-color: var(--admin-secondary);
        }

        .progress {
            background: rgba(255, 255, 255, 0.1);
        }

        .progress-bar {
            transition: width 0.6s ease;
        }

        .list-group-item {
            background: transparent;
            border-color: var(--glass-border);
        }

        .modal-content {
            background: rgba(31, 41, 55, 0.95);
            backdrop-filter: blur(10px);
        }

        .form-control,
        .form-select {
            background: rgba(0, 0, 0, 0.3);
            border-color: var(--glass-border);
            color: white;
        }

        .form-control:focus,
        .form-select:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: var(--admin-primary);
            color: white;
            box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.25);
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .alert {
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
        }

        .badge {
            font-size: 0.75rem;
        }

        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }
            
            .sidebar.show {
                transform: translateX(0);
            }
            
            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="p-4">
            <h4 class="text-white">
                <i class="bi bi-shield-check me-2"></i>EcoCity Admin
            </h4>
        </div>
        
        <nav class="nav flex-column">
            <a class="nav-link active" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Initiative" asp-action="Pending">
                <i class="bi bi-clock-history me-2"></i>Initiatives en attente
            </a>
            <a class="nav-link" asp-area="" asp-controller="Initiative" asp-action="Index">
                <i class="bi bi-lightbulb me-2"></i>Toutes les initiatives
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="User" asp-action="Index">
                <i class="bi bi-people me-2"></i>Utilisateurs
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Category" asp-action="Index">
                <i class="bi bi-tags me-2"></i>Catégories
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Report" asp-action="Index">
                <i class="bi bi-file-text me-2"></i>Rapports
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                <i class="bi bi-gear me-2"></i>Paramètres
            </a>
        </nav>
        
        <div class="mt-auto p-4">
            <div class="border-top border-secondary pt-3">
                <small class="text-white-50 d-block">
                    <i class="bi bi-person-circle me-2"></i>
                    @User.Identity.Name
                </small>
                <a asp-area="Admin" asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger mt-2">
                    <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                </a>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Navbar -->
        <nav class="navbar-admin d-flex justify-content-between align-items-center">
            <button class="btn btn-outline-light d-md-none" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            
            <div class="d-flex align-items-center">
                <h5 class="mb-0 me-3">@ViewData["Title"]</h5>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <div class="dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        <span class="badge bg-danger ms-1">3</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end bg-dark text-white">
                        <li><h6 class="dropdown-header">Notifications</h6></li>
                        <li><a class="dropdown-item text-white" href="#">3 initiatives en attente</a></li>
                        <li><a class="dropdown-item text-white" href="#">Nouvel utilisateur inscrit</a></li>
                        <li><hr class="dropdown-divider border-secondary"></li>
                        <li><a class="dropdown-item text-white" asp-area="Admin" asp-controller="Initiative" asp-action="Pending">Voir tout</a></li>
                    </ul>
                </div>
                
                <a href="/" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-house me-1"></i>Voir le site
                </a>
            </div>
        </nav>

        <!-- Page Content -->
        <main>
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @Html.AntiForgeryToken()
    
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('show');
        }

        // Auto-hide sidebar on mobile when clicking outside
        document.addEventListener('click', function(event) {
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = event.target.closest('button[onclick="toggleSidebar()"]');
            
            if (window.innerWidth <= 768 && !sidebar.contains(event.target) && !toggleBtn) {
                sidebar.classList.remove('show');
            }
        });

        // Animate progress bars on page load
        window.addEventListener('load', function() {
            const progressBars = document.querySelectorAll('.progress-bar');
            progressBars.forEach(bar => {
                const width = bar.style.width;
                bar.style.width = '0%';
                setTimeout(() => {
                    bar.style.width = width;
                }, 100);
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
