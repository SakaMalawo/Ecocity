@model EcoCity.ViewModels.MemberDashboardViewModel
@{
    ViewData["Title"] = "Statistiques - Espace Membre";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-white mb-3">
                <i class="bi bi-graph-up me-2"></i> Vos Statistiques
            </h1>
            <p class="lead text-white-50">Suivez votre contribution à la communauté EcoCity</p>
        </div>
    </div>

    <!-- Navigation rapide -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="glass-card p-3">
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Dashboard", "Member", new { area = "" })" class="btn btn-glass btn-sm">
                        <i class="bi bi-speedometer2 me-1"></i> Tableau de bord
                    </a>
                    <a href="@Url.Action("MyInitiatives", "Member", new { area = "" })" class="btn btn-glass btn-sm">
                        <i class="bi bi-lightbulb me-1"></i> Mes initiatives
                    </a>
                    <a href="@Url.Action("SupportedInitiatives", "Member", new { area = "" })" class="btn btn-glass btn-sm">
                        <i class="bi bi-heart me-1"></i> Initiatives soutenues
                    </a>
                    <a href="@Url.Action("Messages", "Member", new { area = "" })" class="btn btn-glass btn-sm">
                        <i class="bi bi-envelope me-1"></i> Messages
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistiques principales -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="glass-card p-4 text-center">
                <i class="bi bi-lightbulb text-warning fs-2 mb-2"></i>
                <h3 class="text-white fw-bold mb-1">@Model.TotalInitiatives</h3>
                <p class="text-white-50 mb-0">Initiatives créées</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="glass-card p-4 text-center">
                <i class="bi bi-check-circle text-success fs-2 mb-2"></i>
                <h3 class="text-white fw-bold mb-1">@Model.PublishedInitiatives</h3>
                <p class="text-white-50 mb-0">Initiatives publiées</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="glass-card p-4 text-center">
                <i class="bi bi-clock text-info fs-2 mb-2"></i>
                <h3 class="text-white fw-bold mb-1">@Model.PendingInitiatives</h3>
                <p class="text-white-50 mb-0">En attente</p>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="glass-card p-4 text-center">
                <i class="bi bi-hand-thumbs-up text-primary fs-2 mb-2"></i>
                <h3 class="text-white fw-bold mb-1">@Model.TotalVotes</h3>
                <p class="text-white-50 mb-0">Votes donnés</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="glass-card p-4 text-center">
                <i class="bi bi-chat text-info fs-2 mb-2"></i>
                <h3 class="text-white fw-bold mb-1">@Model.TotalComments</h3>
                <p class="text-white-50 mb-0">Commentaires</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="glass-card p-4 text-center">
                <i class="bi bi-trophy text-warning fs-2 mb-2"></i>
                <h3 class="text-white fw-bold mb-1">@(Model.TotalInitiatives > 0 ? Math.Round((double)Model.PublishedInitiatives / Model.TotalInitiatives * 100) : 0)%</h3>
                <p class="text-white-50 mb-0">Taux d'approbation</p>
            </div>
        </div>
    </div>

    <!-- Profil résumé -->
    <div class="row">
        <div class="col-12">
            <div class="glass-card p-4">
                <h4 class="text-white fw-bold mb-3">
                    <i class="bi bi-person me-2"></i> Résumé du profil
                </h4>
                <div class="row">
                    <div class="col-md-6">
                        <p class="text-white-50"><strong class="text-white">Nom :</strong> @Model.FirstName @Model.LastName</p>
                        <p class="text-white-50"><strong class="text-white">Email :</strong> @Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-white-50"><strong class="text-white">Initiatives :</strong> @Model.TotalInitiatives total, @Model.PublishedInitiatives publiées</p>
                        <p class="text-white-50"><strong class="text-white">Engagement :</strong> @Model.TotalVotes votes, @Model.TotalComments commentaires</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
