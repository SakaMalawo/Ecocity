@model EcoCity.ViewModels.InitiativeIndexViewModel
@{
    ViewData["Title"] = "Initiatives - EcoCity";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-bold mb-3">Initiatives Écologiques</h1>
                    <p class="lead text-muted">Découvrez et soutenez les projets pour un avenir durable</p>
                </div>
                <a href="@Url.Action("Create", "Initiative")" class="btn btn-success btn-lg">
                    <i class="bi bi-plus-circle-fill me-2"></i>Proposer une initiative
                </a>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label for="search" class="form-label">Rechercher</label>
                            <input type="text" class="form-control" id="search" name="search" placeholder="Mots-clés..." value="@ViewData["Search"]">
                        </div>
                        <div class="col-md-3">
                            <label for="category" class="form-label">Catégorie</label>
                            <select class="form-select" id="category" name="category">
                                <option value="">Toutes les catégories</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="sortBy" class="form-label">Trier par</label>
                            <select class="form-select" id="sortBy" name="sortBy">
                                <option value="recent">Plus récentes</option>
                                <option value="popular">Plus populaires</option>
                                <option value="votes">Plus de votes</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-1"></i>Filtrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Grille d'initiatives -->
    <div class="row">
        @if (Model.Initiatives != null && Model.Initiatives.Any())
        {
            @foreach (var initiative in Model.Initiatives)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(initiative.ImageUrl))
                        {
                            <img src="@initiative.ImageUrl" class="card-img-top" alt="@initiative.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-success">@initiative.Category?.Name</span>
                                <div class="text-warning">
                                    <i class="bi bi-star-fill"></i> @initiative.VotesCount
                                </div>
                            </div>
                            <h5 class="card-title">@initiative.Title</h5>
                            <p class="card-text text-muted flex-grow-1">
                                @(initiative.Description?.Length > 120 ? initiative.Description.Substring(0, 120) + "..." : initiative.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <small class="text-muted">
                                    <i class="bi bi-person-circle me-1"></i>@initiative.User?.UserName
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>@initiative.CreatedAt.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                                <a href="@Url.Action("Details", "Initiative", new { id = initiative.Id })" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i>Voir détails
                                </a>
                                <button class="btn btn-outline-success btn-sm" onclick="voteForInitiative(@initiative.Id)">
                                    <i class="bi bi-hand-thumbs-up me-1"></i>Soutenir
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h3 class="mt-3">Aucune initiative trouvée</h3>
                    <p class="text-muted mb-4">Soyez le premier à proposer une initiative écologique !</p>
                    <a href="@Url.Action("Create", "Initiative")" class="btn btn-success btn-lg">
                        <i class="bi bi-plus-circle-fill me-2"></i>Créer une initiative
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.Initiatives != null && Model.Initiatives.Count > 0)
    {
        <div class="row mt-4">
            <div class="col-12">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1">Précédent</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Suivant</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function voteForInitiative(initiativeId) {
            // Implementation du vote via AJAX
            fetch('/Initiative/Vote', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ initiativeId: initiativeId })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Une erreur est survenue');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Une erreur est survenue lors du vote');
            });
        }
    </script>
}
