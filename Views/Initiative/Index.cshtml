@model EcoCity.ViewModels.InitiativeIndexViewModel
@{
    ViewData["Title"] = "Fil d'actualités - EcoCity";
}

<div class="container py-5">
    <!-- Header avec filtres -->
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold text-white mb-3">Fil d'actualités des Initiatives</h1>
        <p class="lead text-white-50 mb-4">Découvrez et soutenez tous les projets écologiques de la communauté</p>
        <a href="@Url.Action("Create", "Initiative", new { area = "" })" class="btn btn-glass-eco btn-lg pulse-element">
            <i class="bi bi-plus-circle me-2"></i>Proposer une initiative
        </a>
    </div>

    <!-- Filtres compactés -->
    <div class="glass-card p-3 mb-4">
        <form method="get" asp-area="" asp-controller="Initiative" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" class="form-control" id="search" name="search" placeholder="Rechercher..." value="@ViewData["Search"]">
            </div>
            <div class="col-md-3">
                <select class="form-select" id="category" name="category">
                    <option value="">Toutes les catégories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" id="sortBy" name="sortBy">
                    <option value="recent">Plus récentes</option>
                    <option value="popular">Plus populaires</option>
                    <option value="votes">Plus de votes</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-glass w-100">
                    <i class="bi bi-search me-1"></i>Filtrer
                </button>
            </div>
        </form>
    </div>

    <!-- Fil d'actualités des initiatives -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (Model.Initiatives != null && Model.Initiatives.Any())
            {
                @foreach (var initiative in Model.Initiatives)
                {
                    <div class="initiative-post mb-4 border border-secondary rounded p-3">
                        <!-- En-tête du post -->
                        <div class="d-flex align-items-center mb-3">
                            <div class="user-avatar-lg me-3">
                                <img src="https://picsum.photos/seed/@(initiative.User?.UserName ?? "user")/50/50.jpg" 
                                     alt="Avatar" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;">
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="text-white fw-bold mb-1">@(initiative.User?.UserName ?? "Utilisateur anonyme")</h6>
                                <div class="d-flex align-items-center text-white-50 small">
                                    <span class="category-pill me-2">@(initiative.Category?.Name ?? "Non catégorisée")</span>
                                    <span><i class="bi bi-clock me-1"></i>@(initiative.CreatedAt.ToString("dd MMM yyyy à HH:mm"))</span>
                                </div>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-glass btn-sm" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-flag me-2"></i>Signaler</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-bookmark me-2"></i>Sauvegarder</a></li>
                                </ul>
                            </div>
                        </div>

                        <!-- Contenu du post -->
                        <div class="post-content">
                            <h4 class="text-white fw-bold mb-3">@(initiative.Title ?? "Titre non défini")</h4>
                            <p class="text-white-50 mb-3">@(initiative.Description ?? "Description non disponible")</p>
                            
                            @if (!string.IsNullOrEmpty(initiative.ImageUrl))
                            {
                                <div class="post-image mb-3">
                                    <img src="@initiative.ImageUrl" class="img-fluid rounded" style="max-width: 400px; max-height: 300px; object-fit: cover; width: 100%;" alt="@(initiative.Title ?? "Image")">
                                </div>
                            }
                            else
                            {
                                <div class="post-image mb-3">
                                    <div class="bg-gradient-primary d-flex align-items-center justify-content-center rounded" style="height: 200px;">
                                        <i class="bi bi-image text-white fs-1 opacity-50"></i>
                                    </div>
                                </div>
                            }
                            
                            @if (!string.IsNullOrEmpty(initiative.Location))
                            {
                                <div class="location-info mb-3">
                                    <i class="bi bi-geo-alt text-info me-2"></i>
                                    <span class="text-white-50">@initiative.Location</span>
                                </div>
                            }
                            
                            @if (!string.IsNullOrEmpty(initiative.Goals))
                            {
                                <div class="goals-info mb-3">
                                    <h6 class="text-white fw-bold mb-2"><i class="bi bi-target me-2"></i>Objectifs</h6>
                                    <p class="text-white-50 small mb-0">@(initiative.Goals ?? "")</p>
                                </div>
                            }
                        </div>

                        <!-- Actions du post -->
                        <div class="post-actions d-flex justify-content-between align-items-center pt-3 border-top border-secondary">
                            <div class="action-buttons">
                                <button class="btn btn-glass btn-sm me-2" onclick="voteForInitiative(@initiative.Id, true)">
                                    <i class="bi bi-hand-thumbs-up me-1"></i>
                                    <span class="vote-count">@(initiative.VotesCount)</span>
                                </button>
                                <button class="btn btn-glass btn-sm me-2" onclick="toggleComments(@initiative.Id)">
                                    <i class="bi bi-chat me-1"></i>
                                    <span class="comment-count">@(initiative.Comments?.Count ?? 0)</span>
                                </button>
                                <button class="btn btn-glass btn-sm me-2" onclick="shareInitiative(@initiative.Id)">
                                    <i class="bi bi-share me-1"></i>
                                    Partager
                                </button>
                            </div>
                            <div>
                                <a href="@Url.Action("Details", "Initiative", new { id = initiative.Id })" 
                                   class="btn btn-glass-eco btn-sm">
                                    <i class="bi bi-arrow-right me-1"></i>Voir les détails
                                </a>
                            </div>
                        </div>

                        <!-- Section commentaires (cachée par défaut) -->
                        <div class="comments-section mt-3 pt-3 border-top border-secondary" id="comments-@initiative.Id" style="display: none;">
                            <div class="comment-form mb-3">
                                <div class="d-flex">
                                    <img src="https://picsum.photos/seed/currentuser/40/40.jpg" 
                                         alt="Your Avatar" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                    <div class="flex-grow-1">
                                        <textarea class="form-control" placeholder="Ajoutez un commentaire..." rows="2"></textarea>
                                        <button class="btn btn-glass-eco btn-sm mt-2">Commenter</button>
                                    </div>
                                </div>
                            </div>
                            
                            @if (initiative.Comments?.Any() == true)
                            {
                                @foreach (var comment in initiative.Comments.Take(3))
                                {
                                    <div class="comment mb-2">
                                        <div class="d-flex">
                                            <img src="https://picsum.photos/seed/@(comment.User?.UserName ?? "commenter")/40/40.jpg" 
                                                 alt="Avatar" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between">
                                                    <h6 class="text-white fw-bold small mb-1">@comment.User?.UserName</h6>
                                                    <small class="text-white-50">@comment.CreatedAt.ToString("dd MMM HH:mm")</small>
                                                </div>
                                                <p class="text-white-50 small mb-0">@comment.Content</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="glass-card p-5 text-center">
                    <i class="bi bi-lightbulb text-white fs-1 mb-3"></i>
                    <h4 class="text-white mb-3">Aucune initiative trouvée</h4>
                    <p class="text-white-50 mb-4">Aucune initiative ne correspond à vos critères de recherche.</p>
                    <a href="@Url.Action("Create", "Initiative")" class="btn btn-glass-eco pulse-element">
                        <i class="bi bi-plus-circle me-2"></i>Créer la première initiative
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Scripts pour les interactions réseau social -->
<script>
    // Vote function
    function voteForInitiative(initiativeId, isUpvote) {
        const voteBtn = event.target.closest('.btn-glass');
        
        fetch('/Initiative/Vote', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify({
                initiativeId: initiativeId,
                isUpvote: isUpvote
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                voteBtn.classList.add('voted');
                voteBtn.innerHTML = '<i class="bi bi-hand-thumbs-up-fill me-1"></i><span class="vote-count">' + data.newVoteCount + '</span>';
                
                voteBtn.style.transform = 'scale(1.2)';
                setTimeout(() => {
                    voteBtn.style.transform = 'scale(1)';
                }, 200);
            }
        })
        .catch(error => console.error('Error:', error));
    }
    
    // Toggle comments section
    function toggleComments(initiativeId) {
        const commentsSection = document.getElementById('comments-' + initiativeId);
        const commentBtn = event.target.closest('.btn-glass');
        
        if (commentsSection.style.display === 'none') {
            commentsSection.style.display = 'block';
            commentBtn.innerHTML = '<i class="bi bi-chat-fill me-1"></i><span class="comment-count">' + 
                commentsSection.querySelectorAll('.comment').length + '</span>';
            
            commentsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
            commentsSection.style.display = 'none';
            commentBtn.innerHTML = '<i class="bi bi-chat me-1"></i><span class="comment-count">' + 
                commentsSection.querySelectorAll('.comment').length + '</span>';
        }
    }
    
    // Share initiative
    function shareInitiative(initiativeId) {
        const shareUrl = window.location.origin + '/Initiative/Details/' + initiativeId;
        
        if (navigator.share) {
            navigator.share({
                title: 'Découvrez cette initiative écologique',
                text: 'Rejoignez-nous dans cette belle initiative pour un avenir durable !',
                url: shareUrl
            }).then(() => {
                console.log('Shared successfully');
            }).catch((error) => {
                console.log('Error sharing:', error);
                copyToClipboard(shareUrl);
            });
        } else {
            copyToClipboard(shareUrl);
        }
    }
    
    function copyToClipboard(text) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        
        try {
            document.execCommand('copy');
            showNotification('Lien copié dans le presse-papiers !', 'success');
        } catch (err) {
            console.error('Failed to copy text: ', err);
            showNotification('Erreur lors de la copie du lien', 'error');
        }
        
        document.body.removeChild(textarea);
    }
    
    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `alert alert-${type === 'success' ? 'success' : 'info'} alert-dismissible fade show position-fixed`;
        notification.style.cssText = 'top: 100px; right: 20px; z-index: 9999; min-width: 300px;';
        notification.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            if (notification.parentNode) {
                notification.remove();
            }
        }, 3000);
    }
    
    // Handle comment submission
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.comment-form button').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const textarea = this.parentElement.querySelector('textarea');
                const commentText = textarea.value.trim();
                
                if (commentText) {
                    const commentSection = this.closest('.comments-section');
                    const commentsList = commentSection.querySelector('.comment-form').nextElementSibling;
                    
                    const newComment = document.createElement('div');
                    newComment.className = 'comment mb-2';
                    newComment.innerHTML = `
                        <div class="d-flex">
                            <img src="https://picsum.photos/seed/currentuser/40/40.jpg" 
                                 alt="Your Avatar" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between">
                                    <h6 class="text-white fw-bold small mb-1">Vous</h6>
                                    <small class="text-white-50">À l'instant</small>
                                </div>
                                <p class="text-white-50 small mb-0">${commentText}</p>
                            </div>
                        </div>
                    `;
                    
                    if (commentsList) {
                        commentsList.insertBefore(newComment, commentsList.firstChild);
                    } else {
                        commentSection.appendChild(newComment);
                    }
                    
                    textarea.value = '';
                    showNotification('Commentaire ajouté avec succès !', 'success');
                }
            });
        });
    });
</script>
