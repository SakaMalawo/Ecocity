@model EcoCity.ViewModels.InitiativeDetailsViewModel
@{
    ViewData["Title"] = Model.Initiative?.Title + " - EcoCity";
}

<div class="container py-5">
    @if (Model.Initiative != null)
    {
        <div class="row">
            <!-- Contenu principal -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    @if (!string.IsNullOrEmpty(Model.Initiative.ImageUrl))
                    {
                        <img src="@Model.Initiative.ImageUrl" class="card-img-top" alt="@Model.Initiative.Title" style="height: 400px; object-fit: cover;">
                    }
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <span class="badge bg-success fs-6">@Model.Initiative.Category?.Name</span>
                                @if (!string.IsNullOrEmpty(Model.Initiative.Location))
                                {
                                    <span class="badge bg-info text-dark fs-6 ms-2">
                                        <i class="bi bi-geo-alt-fill me-1"></i>@Model.Initiative.Location
                                    </span>
                                }
                            </div>
                            <div class="text-end">
                                <div class="text-warning fs-4">
                                    <i class="bi bi-star-fill"></i> @Model.Initiative.VotesCount
                                </div>
                                <small class="text-muted">votes</small>
                            </div>
                        </div>

                        <h1 class="card-title fw-bold mb-3">@Model.Initiative.Title</h1>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <strong>Par:</strong> 
                                <span class="text-primary">@Model.Initiative.User?.UserName</span>
                            </div>
                            <div class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>
                                Créée le @Model.Initiative.CreatedAt.ToString("dd MMMM yyyy")
                            </div>
                        </div>

                        <div class="mb-4">
                            <h4 class="fw-bold mb-3">Description</h4>
                            <p class="card-text text-muted">@Model.Initiative.Description</p>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Initiative.Goals))
                        {
                            <div class="mb-4">
                                <h4 class="fw-bold mb-3">Objectifs</h4>
                                <p>@Model.Initiative.Goals</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Initiative.RequiredResources))
                        {
                            <div class="mb-4">
                                <h4 class="fw-bold mb-3">Ressources nécessaires</h4>
                                <p>@Model.Initiative.RequiredResources</p>
                            </div>
                        }

                        @if (Model.Initiative.Budget.HasValue)
                        {
                            <div class="mb-4">
                                <h4 class="fw-bold mb-3">Budget estimé</h4>
                                <p class="fs-4 text-success">@Model.Initiative.Budget.Value.ToString("N0") €</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Initiative.Duration))
                        {
                            <div class="mb-4">
                                <h4 class="fw-bold mb-3">Durée estimée</h4>
                                <p>@Model.Initiative.Duration</p>
                            </div>
                        }

                        @if (Model.Initiative.TargetDate.HasValue)
                        {
                            <div class="mb-4">
                                <h4 class="fw-bold mb-3">Date cible</h4>
                                <p>@Model.Initiative.TargetDate.Value.ToString("dd MMMM yyyy")</p>
                            </div>
                        }

                        <!-- Actions -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4">
                            <button class="btn btn-success btn-lg" onclick="voteForInitiative(@Model.Initiative.Id)">
                                <i class="bi bi-hand-thumbs-up-fill me-2"></i>Soutenir cette initiative
                            </button>
                            <div>
                                <button class="btn btn-outline-primary me-2">
                                    <i class="bi bi-share-fill me-2"></i>Partager
                                </button>
                                <button class="btn btn-outline-secondary">
                                    <i class="bi bi-bookmark-fill me-2"></i>Sauvegarder
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section commentaires -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4">
                            <i class="bi bi-chat-dots-fill me-2"></i>Commentaires (@Model.Initiative.Comments?.Count ?? 0)
                        </h4>

                        <!-- Formulaire de commentaire -->
                        <div class="mb-4">
                            <form id="commentForm">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <textarea class="form-control" id="commentText" rows="3" 
                                              placeholder="Partagez votre opinion sur cette initiative..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send-fill me-2"></i>Publier le commentaire
                                </button>
                            </form>
                        </div>

                        <!-- Liste des commentaires -->
                        <div id="commentsList">
                            @if (Model.Initiative.Comments != null && Model.Initiative.Comments.Any())
                            {
                                @foreach (var comment in Model.Initiative.Comments.OrderByDescending(c => c.CreatedAt))
                                {
                                    <div class="border-bottom pb-3 mb-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <strong>@comment.User?.UserName</strong>
                                                <small class="text-muted ms-2">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                            </div>
                                        </div>
                                        <p class="mb-0">@comment.Content</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center text-muted py-3">
                                    <i class="bi bi-chat-square-dots" style="font-size: 2rem;"></i>
                                    <p class="mt-2">Soyez le premier à commenter cette initiative !</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Statistiques -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Statistiques</h5>
                        <div class="row text-center">
                            <div class="col-6 mb-3">
                                <div class="text-primary fs-3 fw-bold">@Model.Initiative.VotesCount</div>
                                <small class="text-muted">Votes</small>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="text-info fs-3 fw-bold">@(Model.Initiative.Comments?.Count ?? 0)</div>
                                <small class="text-muted">Commentaires</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Compétences recherchées -->
                @if (!string.IsNullOrEmpty(Model.Initiative.RequiredSkills))
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-3">Compétences recherchées</h5>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var skill in Model.Initiative.RequiredSkills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge bg-light text-dark">@skill.Trim()</span>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Actions rapides -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Actions</h5>
                        
                        @if (Model.CanEdit)
                        {
                            <div class="d-grid gap-2 mb-3">
                                <a href="@Url.Action("Edit", new { id = Model.Initiative.Id })" class="btn btn-primary">
                                    <i class="bi bi-pencil-fill me-2"></i>Modifier l'initiative
                                </a>
                                <button class="btn btn-danger" onclick="confirmDelete(@Model.Initiative.Id)">
                                    <i class="bi bi-trash-fill me-2"></i>Supprimer l'initiative
                                </button>
                            </div>
                        }
                        
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary">
                                <i class="bi bi-person-plus-fill me-2"></i>Contacter le porteur
                            </button>
                            <button class="btn btn-outline-info">
                                <i class="bi bi-flag-fill me-2"></i>Signaler un problème
                            </button>
                            <button class="btn btn-outline-secondary">
                                <i class="bi bi-download me-2"></i>Télécharger en PDF
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Initiatives similaires -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Initiatives similaires</h5>
                        <div class="list-group list-group-flush">
                            <!-- Similar initiatives will be loaded dynamically -->
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-lightbulb" style="font-size: 2rem;"></i>
                                <p class="mt-2 small">Chargement...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 4rem;"></i>
            <h3 class="mt-3">Initiative non trouvée</h3>
            <p class="text-muted">L'initiative que vous recherchez n'existe pas ou a été supprimée.</p>
            <a href="@Url.Action("Index", "Initiative")" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i>Retour aux initiatives
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function voteForInitiative(initiativeId) {
            fetch('/Initiative/Vote', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ 
                    initiativeId: initiativeId,
                    isUpvote: true // Par défaut, vote positif
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Une erreur est survenue');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Une erreur est survenue lors du vote');
            });
        }

        function confirmDelete(initiativeId) {
            if (confirm('Êtes-vous sûr de vouloir supprimer cette initiative ? Cette action est irréversible.')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/Initiative/Delete/${initiativeId}`;
                form.innerHTML = '<input type="hidden" name="__RequestVerificationToken" value="' + document.querySelector('input[name="__RequestVerificationToken"]').value + '" />';
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Comment form submission
        document.getElementById('commentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const commentText = document.getElementById('commentText').value.trim();
            if (!commentText) {
                alert('Veuillez écrire un commentaire');
                return;
            }

            fetch('/Initiative/AddComment', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ 
                    initiativeId: @Model.Initiative.Id,
                    content: commentText 
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Une erreur est survenue');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Une erreur est survenue lors de l\'ajout du commentaire');
            });
        });
    </script>
}
