@model EcoCity.ViewModels.InitiativeCreateViewModel
@{
    ViewData["Title"] = "Proposer une initiative - EcoCity";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-white mb-3">Proposer une Initiative</h1>
                <p class="lead text-white-50">Partagez vos idées pour un avenir plus durable</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @ViewData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Erreurs de validation:</strong>
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="glass-card">
                <div class="card-body p-5">
                    <form method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-8 mb-4">
                                <label asp-for="Title" class="form-label fw-semibold text-white">Titre de l'initiative *</label>
                                <input asp-for="Title" class="form-control" placeholder="Ex: Jardin communautaire du quartier" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-4">
                                <label asp-for="CategoryId" class="form-label fw-semibold text-white">Catégorie *</label>
                                <select asp-for="CategoryId" class="form-select">
                                    <option value="">Sélectionner une catégorie</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var category in ViewBag.Categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold text-white">Description détaillée *</label>
                            <textarea asp-for="Description" class="form-control" rows="5" 
                                      placeholder="Décrivez votre initiative en détail..."></textarea>
                            <div class="form-text text-white-50">Expliquez votre idée, les bénéfices attendus et comment vous prévoyez de la réaliser</div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Location" class="form-label fw-semibold text-white">Lieu de l'initiative *</label>
                                <input asp-for="Location" class="form-control" placeholder="Ex: Paris 15ème arrondissement" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="TargetDate" class="form-label fw-semibold text-white">Date cible</label>
                                <input asp-for="TargetDate" class="form-control" type="date" />
                                <span asp-validation-for="TargetDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Goals" class="form-label fw-semibold text-white">Objectifs *</label>
                            <textarea asp-for="Goals" class="form-control" rows="3"
                                      placeholder="Quels sont les objectifs spécifiques de cette initiative ?"></textarea>
                            <span asp-validation-for="Goals" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Budget" class="form-label fw-semibold text-white">Budget estimé (en euros)</label>
                                <input asp-for="Budget" class="form-control" type="number" min="0" step="0.01" placeholder="Ex: 1000" />
                                <span asp-validation-for="Budget" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Duration" class="form-label fw-semibold text-white">Durée estimée *</label>
                                <input asp-for="Duration" class="form-control" placeholder="Ex: 3 mois" />
                                <span asp-validation-for="Duration" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RequiredResources" class="form-label fw-semibold text-white">Ressources requises *</label>
                            <textarea asp-for="RequiredResources" class="form-control" rows="3"
                                      placeholder="De quelles ressources avez-vous besoin ? (matériel, bénévoles, etc.)"></textarea>
                            <span asp-validation-for="RequiredResources" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RequiredSkills" class="form-label fw-semibold text-white">Compétences recherchées *</label>
                            <textarea asp-for="RequiredSkills" class="form-control" rows="2"
                                      placeholder="Quelles compétences sont nécessaires pour ce projet ?"></textarea>
                            <span asp-validation-for="RequiredSkills" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageFile" class="form-label fw-semibold text-white">Image (optionnel)</label>
                            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                            <div class="form-text text-white-50">Formats acceptés: JPG, PNG, GIF (max 5MB)</div>
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-glass-eco btn-lg px-5">
                                <i class="bi bi-send-fill me-2"></i> Proposer l'initiative
                            </button>
                            <a href="@Url.Action("Index", "Home")" class="btn btn-glass btn-lg px-5 ms-3">
                                <i class="bi bi-x-circle me-2"></i> Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
